<Window x:Class="ExcursionTextbook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ExcursionTextbook.ViewModels"
        xmlns:views="clr-namespace:ExcursionTextbook.Views"
        Title="Экскурсоведение — Электронный учебник"
        Height="700" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource AppBackground}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <vm:EnumToVisibilityConverter x:Key="EnumToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{DynamicResource TopBarBackground}">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="📚 Экскурсоведение"
                           FontSize="17" FontWeight="Bold"
                           Foreground="{DynamicResource TopBarForeground}"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>

                <Border x:Name="SearchBorder"
                        Grid.Column="1"
                        Background="{DynamicResource SearchBarBackground}"
                        BorderBrush="{DynamicResource SearchBarIdleBorder}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,8" MaxWidth="400" HorizontalAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" Margin="8,0,4,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Opacity="0.8"/>
                        <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource AppForeground}"
                                 CaretBrush="{DynamicResource AppForeground}"
                                 VerticalAlignment="Center" Padding="4,6"
                                 FontSize="13"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="SearchBox"
                                 GotFocus="SearchBox_GotFocus"
                                 LostFocus="SearchBox_LostFocus">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </Grid>
                </Border>

                <Button Grid.Column="2" Content="🎬 Видео"
                        Style="{StaticResource TopBarButton}" Margin="8,0,0,0"
                        Command="{Binding ShowVideoCommand}"/>

                <Button Grid.Column="3" Content="© Авторство"
                        Style="{StaticResource TopBarButton}" Margin="8,0,0,0"
                        Command="{Binding ShowAboutCommand}"/>

                <Button Grid.Column="4" Content="📖 Глоссарий"
                        Style="{StaticResource TopBarButton}" Margin="8,0,0,0"
                        Command="{Binding ShowGlossaryCommand}"/>

                <Button Grid.Column="5" Content="🔖 Закладки"
                        Style="{StaticResource TopBarButton}" Margin="8,0,0,0"
                        Command="{Binding ShowBookmarksCommand}"/>

                <Button Grid.Column="6" Content="{Binding ThemeButtonText}"
                        Style="{StaticResource TopBarButton}" Margin="8,0,0,0"
                        Command="{Binding ToggleThemeCommand}"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="180" MaxWidth="350"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation Panel -->
            <Border Grid.Column="0" Background="{DynamicResource NavBackground}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="С О Д Е Р Ж А Н И Е"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="12,10,12,6"/>

                    <ScrollViewer x:Name="NavScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="NavTree"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ItemsSource="{Binding NavItems}"
                                  SelectedItemChanged="NavTree_SelectedItemChanged"
                                  PreviewMouseWheel="NavTree_PreviewMouseWheel">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <!-- Chapter header — visually a non-clickable group label -->
                                    <Border BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="2,0,0,0"
                                            Padding="6,5,4,5"
                                            IsHitTestVisible="False">
                                        <TextBlock Text="{Binding Title}"
                                                   TextWrapping="Wrap"
                                                   FontWeight="Bold"
                                                   FontSize="12.5"
                                                   Foreground="{DynamicResource ChapterHeaderForeground}"/>
                                    </Border>
                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✓ " Foreground="{DynamicResource ReadMarkColor}"
                                                           FontWeight="Bold"
                                                           Visibility="{Binding IsRead, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap"
                                                           Padding="2,3"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="True"/>
                                    <Setter Property="Foreground" Value="{DynamicResource NavForeground}"/>
                                    <Setter Property="Padding" Value="4,3"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition/>
                                                    </Grid.RowDefinitions>
                                                    <Border x:Name="ItemBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderThickness="0"
                                                            Padding="{TemplateBinding Padding}"
                                                            CornerRadius="4"
                                                            Margin="4,1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ToggleButton x:Name="Expander"
                                                                          Grid.Column="0"
                                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                          Visibility="{Binding HasItems, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}"
                                                                          Width="16" Height="16"
                                                                          Background="Transparent" BorderThickness="0"
                                                                          Focusable="False">
                                                                <ToggleButton.Style>
                                                                    <Style TargetType="ToggleButton">
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="ToggleButton">
                                                                                    <TextBlock x:Name="Arrow" Text="▶"
                                                                                               FontSize="8"
                                                                                               Foreground="{DynamicResource AccentBrush}"
                                                                                               VerticalAlignment="Center"/>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsChecked" Value="True">
                                                                                            <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </ToggleButton.Style>
                                                            </ToggleButton>
                                                            <ContentPresenter Grid.Column="1"
                                                                              ContentSource="Header"
                                                                              HorizontalAlignment="Stretch"/>
                                                        </Grid>
                                                    </Border>
                                                    <ItemsPresenter x:Name="ItemsHost" Grid.Row="1"
                                                                    Margin="16,0,0,0"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <!-- Hover first — IsSelected comes after and wins when both active -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background"
                                                                Value="{DynamicResource NavHoverBrush}"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background"
                                                                Value="{DynamicResource SelectionBrush}"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsExpanded" Value="False">
                                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                    <!-- Chapter items: always transparent, no hover/selection, arrow cursor -->
                                                    <DataTrigger Binding="{Binding IsChapter}" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="Transparent"/>
                                                        <Setter TargetName="ItemBorder" Property="Cursor" Value="Arrow"/>
                                                        <Setter TargetName="ItemBorder" Property="Margin" Value="4,8,4,0"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </ScrollViewer>

                    <!-- Quiz button at bottom of nav -->
                    <Button Grid.Row="2"
                            Content="📝 Пройти тест"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartQuizCommand}"
                            Margin="8,6,8,10"/>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"/>

            <!-- Right Panel -->
            <Border Grid.Column="2" Background="{DynamicResource PanelBackground}">
                <Grid>
                    <!-- Section View -->
                    <views:SectionView
                        Visibility="{Binding PanelMode, Converter={StaticResource EnumToVis}, ConverterParameter=Section}"
                        DataContext="{Binding}"/>

                    <!-- Quiz View -->
                    <views:QuizView
                        Visibility="{Binding DataContext.PanelMode,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource EnumToVis}, ConverterParameter=Quiz}"
                        DataContext="{Binding QuizVM}"/>

                    <!-- Glossary View -->
                    <views:GlossaryView
                        Visibility="{Binding PanelMode, Converter={StaticResource EnumToVis}, ConverterParameter=Glossary}"
                        DataContext="{Binding}"/>

                    <!-- Bookmarks View -->
                    <views:BookmarksView
                        Visibility="{Binding PanelMode, Converter={StaticResource EnumToVis}, ConverterParameter=Bookmarks}"
                        DataContext="{Binding}"/>

                    <!-- Search Results View -->
                    <views:SearchResultsView
                        Visibility="{Binding PanelMode, Converter={StaticResource EnumToVis}, ConverterParameter=Search}"
                        DataContext="{Binding}"/>

                    <!-- Video View -->
                    <views:VideoView
                        Visibility="{Binding PanelMode, Converter={StaticResource EnumToVis}, ConverterParameter=Video}"
                        DataContext="{Binding}"/>

                    <!-- About / Authorship View -->
                    <views:AboutView
                        Visibility="{Binding PanelMode, Converter={StaticResource EnumToVis}, ConverterParameter=About}"
                        DataContext="{Binding}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Foreground="{DynamicResource StatusBarForeground}"
                           VerticalAlignment="Center" FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{Binding ProgressText}"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>
</Window>
