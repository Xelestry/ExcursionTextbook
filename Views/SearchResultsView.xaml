<UserControl x:Class="ExcursionTextbook.Views.SearchResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,32" MaxWidth="800">
                <TextBlock Text="Результаты поиска" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource ChapterHeaderForeground}"
                           Margin="0,0,0,8"/>
                <TextBlock FontSize="13" Foreground="{DynamicResource NavForeground}"
                           Opacity="0.7" Margin="0,0,0,24">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSearchResults}" Value="True">
                                    <Setter Property="Text">
                                        <Setter.Value>
                                            <Binding Path="SearchResults.Count" StringFormat="Найдено совпадений: {0}"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasSearchResults}" Value="False">
                                    <Setter Property="Text" Value="По вашему запросу ничего не найдено."/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,20"/>

                <ItemsControl ItemsSource="{Binding SearchResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="16,12"
                                    Background="{DynamicResource NavBackground}"
                                    CornerRadius="6"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.NavigateSearchResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <TextBlock Text="{Binding SectionTitle}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ChapterHeaderForeground}"/>
                                    <TextBlock Text="{Binding ChapterTitle}"
                                               FontSize="12"
                                               Foreground="{DynamicResource NavForeground}"
                                               Opacity="0.7" Margin="0,2,0,4"/>
                                    <TextBlock Text="{Binding Snippet}"
                                               FontSize="13"
                                               Foreground="{DynamicResource AppForeground}"
                                               TextWrapping="Wrap"
                                               Opacity="0.85"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
