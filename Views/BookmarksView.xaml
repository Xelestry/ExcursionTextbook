<UserControl x:Class="ExcursionTextbook.Views.BookmarksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,32" MaxWidth="800">
                <TextBlock Text="Закладки" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource ChapterHeaderForeground}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Сохранённые разделы для быстрого доступа"
                           FontSize="13" Foreground="{DynamicResource NavForeground}"
                           Opacity="0.7" Margin="0,0,0,24"/>
                <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,20"/>

                <TextBlock Text="Закладок пока нет. Добавьте закладку на любом разделе."
                           FontSize="14" Foreground="{DynamicResource NavForeground}"
                           Opacity="0.6" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Bookmarks.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding Bookmarks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="16,12"
                                    Background="{DynamicResource NavBackground}"
                                    CornerRadius="6"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.NavigateBookmarkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding SectionTitle}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ChapterHeaderForeground}"/>
                                        <TextBlock Text="{Binding ChapterTitle}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource NavForeground}"
                                                   Opacity="0.7" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="→"
                                               FontSize="18"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
