<UserControl x:Class="ExcursionTextbook.Views.QuizView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <TextBlock Text="Тест не загружен" VerticalAlignment="Center" HorizontalAlignment="Center"
                   Foreground="{DynamicResource NavForeground}" Opacity="0.5"
                   x:Name="NullText"/>

        <ScrollViewer x:Name="ContentScroll" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
            <StackPanel Margin="40,32,40,32" MaxWidth="700">
                <TextBlock Text="Тест по главе" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource ChapterHeaderForeground}"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="ProgressLabel" FontSize="13"
                           Foreground="{DynamicResource NavForeground}" Opacity="0.7"
                           Margin="0,0,0,24"/>

                <!-- Active question panel -->
                <StackPanel x:Name="QuestionPanel">
                    <Border Background="{DynamicResource NavBackground}"
                            CornerRadius="8" Padding="20" Margin="0,0,0,20"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <TextBlock x:Name="QuestionText"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppForeground}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel x:Name="OptionsPanel"/>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button x:Name="AnswerBtn" Content="Ответить"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,10,0"
                                Click="AnswerBtn_Click"/>
                        <Button x:Name="NextBtn" Content="Следующий →"
                                Style="{StaticResource SecondaryButton}"
                                Visibility="Collapsed"
                                Click="NextBtn_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Result panel -->
                <StackPanel x:Name="ResultPanel" Visibility="Collapsed">
                    <TextBlock Text="Тест завершён!" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource ChapterHeaderForeground}"
                               Margin="0,0,0,20"/>
                    <Border x:Name="ResultBorder" CornerRadius="8" Padding="24"
                            BorderThickness="2" Margin="0,0,0,16">
                        <TextBlock x:Name="ResultLabel" FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
